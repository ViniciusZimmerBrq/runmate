#!/usr/bin/env bash

set -euo pipefail

OWNER="${RUNMATE_OWNER:-ViniciusZimmerBrq}"
REPO="${RUNMATE_REPO:-runmate}"
PROJECT_NUMBER="${RUNMATE_PROJECT_NUMBER:-2}"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
STATE_DIR="$ROOT_DIR/.runmate"
STATE_FILE="$STATE_DIR/ops-state.json"

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

require_cmd gh
require_cmd jq

ensure_state_file() {
  mkdir -p "$STATE_DIR"
  if [[ ! -f "$STATE_FILE" ]]; then
    printf '{"issues":{}}\n' >"$STATE_FILE"
  fi
}

fetch_items() {
  gh project item-list "$PROJECT_NUMBER" --owner "$OWNER" --format json --limit 100
}

issue_json() {
  local issue_number="$1"
  fetch_items | jq -c --argjson issue "$issue_number" '
    .items | map(select(.content.number == $issue)) | .[0]
  '
}

agent_file() {
  case "$1" in
    pm) echo "$ROOT_DIR/agents/PM_AGENT.md" ;;
    po) echo "$ROOT_DIR/agents/PO_AGENT.md" ;;
    ux|uxui|ux/ui) echo "$ROOT_DIR/agents/UX_UI_AGENT.md" ;;
    tech|techlead) echo "$ROOT_DIR/agents/TECH_LEAD_AGENT.md" ;;
    flutter) echo "$ROOT_DIR/agents/FLUTTER_DEV_AGENT.md" ;;
    backend) echo "$ROOT_DIR/agents/BACKEND_CSHARP_AGENT.md" ;;
    security) echo "$ROOT_DIR/agents/SECURITY_AGENT.md" ;;
    qa) echo "$ROOT_DIR/agents/QA_AGENT.md" ;;
    devops) echo "$ROOT_DIR/agents/DEVOPS_AGENT.md" ;;
    pr|prcreator) echo "$ROOT_DIR/agents/PR_CREATOR_AGENT.md" ;;
    review|codereview) echo "$ROOT_DIR/agents/CODE_REVIEW_AGENT.md" ;;
    *) return 1 ;;
  esac
}

agent_label() {
  case "$1" in
    pm) echo "PM" ;;
    po) echo "PO" ;;
    uxui) echo "UX/UI" ;;
    techlead) echo "Tech Lead" ;;
    flutter) echo "Flutter Dev" ;;
    backend) echo "Backend Dev" ;;
    security) echo "Security" ;;
    qa) echo "QA" ;;
    devops) echo "DevOps" ;;
    prcreator) echo "PR Creator" ;;
    codereview) echo "Code Review" ;;
    *) echo "$1" ;;
  esac
}

normalize_agent_key() {
  case "$1" in
    "PM"|pm) echo "pm" ;;
    "PO"|po) echo "po" ;;
    "UX/UI"|uxui|ux|ux/ui) echo "uxui" ;;
    "Tech Lead"|techlead|tech) echo "techlead" ;;
    "Flutter Dev"|flutter) echo "flutter" ;;
    "Backend Dev"|backend) echo "backend" ;;
    "Security"|security) echo "security" ;;
    "QA"|qa) echo "qa" ;;
    "DevOps"|devops) echo "devops" ;;
    "PR Creator"|prcreator|pr) echo "prcreator" ;;
    "Code Review"|codereview|review) echo "codereview" ;;
    *) echo "" ;;
  esac
}

extract_prompt_block() {
  local file="$1"
  awk '
    /^```text$/ {capture=1; next}
    /^```$/ && capture {capture=0; exit}
    capture {print}
  ' "$file"
}

flow_json_for_item() {
  local item_json="$1"
  jq -c '
    . as $item
    | (["pm", "po", "techlead"]) as $base
    | if $item.area == "Flutter" then
        $base + ["uxui", "flutter", "qa", "prcreator"]
      elif $item.area == "Backend" then
        $base + ["backend"]
        + (if ($item.risk == "Security" or $item["secondary Agent"] == "Security") then ["security"] else [] end)
        + ["qa", "prcreator"]
      elif $item.area == "Product" then
        $base
      else
        $base
      end
  ' <<<"$item_json"
}

ensure_issue_state() {
  local issue_number="$1"
  local item_json="$2"
  local flow_json

  ensure_state_file
  flow_json="$(flow_json_for_item "$item_json")"

  local exists
  exists="$(jq -r --arg issue "$issue_number" '.issues[$issue] != null' "$STATE_FILE")"

  if [[ "$exists" != "true" ]]; then
    local tmp
    tmp="$(mktemp)"
    jq --arg issue "$issue_number" --argjson flow "$flow_json" '
      .issues[$issue] = {
        flow: $flow,
        completed: []
      }
    ' "$STATE_FILE" >"$tmp"
    mv "$tmp" "$STATE_FILE"
  fi
}

current_stage_key() {
  local issue_number="$1"
  jq -r --arg issue "$issue_number" '
    .issues[$issue] as $state
    | ($state.completed | length) as $idx
    | if $state.flow[$idx] == null then "" else $state.flow[$idx] end
  ' "$STATE_FILE"
}

next_stage_key() {
  local issue_number="$1"
  jq -r --arg issue "$issue_number" '
    .issues[$issue] as $state
    | ($state.completed | length + 1) as $idx
    | if $state.flow[$idx] == null then "" else $state.flow[$idx] end
  ' "$STATE_FILE"
}

approve_stage() {
  local issue_number="$1"
  local agent_key="$2"
  local tmp
  tmp="$(mktemp)"
  jq --arg issue "$issue_number" --arg agent "$agent_key" '
    .issues[$issue].completed += [$agent]
  ' "$STATE_FILE" >"$tmp"
  mv "$tmp" "$STATE_FILE"
}

print_header() {
  printf "\nRunMate Ops\n"
  printf "Project: %s/%s - board %s\n\n" "$OWNER" "$REPO" "$PROJECT_NUMBER"
}

next_handoff_for_area() {
  case "$1" in
    "Backend") echo "PM -> PO -> Tech Lead -> Backend Dev -> Security -> QA -> PR Creator" ;;
    "Flutter") echo "PM -> PO -> Tech Lead -> UX/UI -> Flutter Dev -> QA -> PR Creator" ;;
    "Product") echo "PM -> PO -> Tech Lead" ;;
    *) echo "PM -> PO -> Tech Lead" ;;
  esac
}

cmd_summary() {
  local items_json
  items_json="$(fetch_items)"

  local total ready in_progress review qa blocked done open_sprints
  total="$(jq '.items | length' <<<"$items_json")"
  ready="$(jq '[.items[] | select(.status == "Ready")] | length' <<<"$items_json")"
  in_progress="$(jq '[.items[] | select(.status == "In Progress")] | length' <<<"$items_json")"
  review="$(jq '[.items[] | select(.status == "Review")] | length' <<<"$items_json")"
  qa="$(jq '[.items[] | select(.status == "QA")] | length' <<<"$items_json")"
  blocked="$(jq '[.items[] | select(.status == "Blocked")] | length' <<<"$items_json")"
  done="$(jq '[.items[] | select(.status == "Done")] | length' <<<"$items_json")"
  open_sprints="$(jq '[.items[].sprint] | unique | map(select(. != null and . != "")) | length' <<<"$items_json")"

  print_header
  cat <<EOF
Planned sprints: $open_sprints
Total tasks: $total

Status:
- Ready: $ready
- In Progress: $in_progress
- Review: $review
- QA: $qa
- Blocked: $blocked
- Done: $done

Core flow:
- Product: PM -> PO -> Tech Lead
- Flutter: PM -> PO -> Tech Lead -> UX/UI -> Flutter Dev -> QA -> PR Creator
- Backend: PM -> PO -> Tech Lead -> Backend Dev -> Security -> QA -> PR Creator

Next commands:
- bash ./scripts/runmate-ops ready
- bash ./scripts/runmate-ops next
- bash ./scripts/runmate-ops start 2
- bash ./scripts/runmate-ops timeline 2
- bash ./scripts/runmate-ops run 2
EOF
}

cmd_ready() {
  local items_json
  items_json="$(fetch_items)"

  print_header
  jq -r '
    .items
    | map(select(.status == "Ready"))
    | sort_by(.priority, .estimate, .content.number)
    | if length == 0 then
        "No tasks in Ready."
      else
        .[]
        | "- #\(.content.number) [\(.priority)] \(.title)\n  Sprint: \(.sprint) | Area: \(.area) | Owner: \(.["primary Agent"]) | Support: \(.["secondary Agent"]) | Risk: \(.risk)"
      end
  ' <<<"$items_json"
}

cmd_next() {
  local items_json
  items_json="$(fetch_items)"

  print_header
  jq -r '
    .items
    | map(select(.status == "Ready"))
    | sort_by(.priority, .estimate, .content.number)
    | .[0] as $item
    | if $item == null then
        "No task ready to pull."
      else
        "Recommended next task:\n" +
        "- #\($item.content.number) \($item.title)\n" +
        "- Priority: \($item.priority)\n" +
        "- Area: \($item.area)\n" +
        "- Primary agent: \($item["primary Agent"])\n" +
        "- Secondary agent: \($item["secondary Agent"])\n" +
        "- Risk: \($item.risk)\n" +
        "- Estimate: \($item.estimate)\n" +
        "\nRequired process:\n" +
        (if $item.area == "Backend" then
          "PM -> PO -> Tech Lead -> Backend Dev -> Security -> QA -> PR Creator"
        elif $item.area == "Flutter" then
          "PM -> PO -> Tech Lead -> UX/UI -> Flutter Dev -> QA -> PR Creator"
        else
          "PM -> PO -> Tech Lead"
        end)
      end
  ' <<<"$items_json"
}

cmd_team() {
  print_header
  cat <<'EOF'
Multi-agent operating flow:

- Product: PM -> PO -> Tech Lead
- Backend: PM -> PO -> Tech Lead -> Backend Dev -> Security -> QA -> PR Creator
- Flutter: PM -> PO -> Tech Lead -> UX/UI -> Flutter Dev -> QA -> PR Creator

Movement rules:
- run <id> only unlocks the next allowed agent
- approve <id> closes the current stage and unlocks the next
- timeline <id> shows the full process for a task
- handoff <id> shows who owns the next pass
EOF
}

cmd_show() {
  local issue_number="${1:-}"
  if [[ -z "$issue_number" ]]; then
    echo "Usage: bash ./scripts/runmate-ops show <issue-number>" >&2
    exit 1
  fi

  local item_json
  item_json="$(issue_json "$issue_number")"
  if [[ "$item_json" == "null" || -z "$item_json" ]]; then
    echo "Issue not found in project." >&2
    exit 1
  fi

  print_header
  jq -r '
    "#\(.content.number) \(.title)\n" +
    "- Status: \(.status)\n" +
    "- Sprint: \(.sprint)\n" +
    "- Priority: \(.priority)\n" +
    "- Area: \(.area)\n" +
    "- Primary agent: \(."primary Agent")\n" +
    "- Secondary agent: \(."secondary Agent")\n" +
    "- Risk: \(.risk)\n" +
    "- Estimate: \(.estimate)\n" +
    "- URL: \(.content.url)\n"
  ' <<<"$item_json"
}

cmd_agents() {
  print_header
  cat <<'EOF'
Available agents:

- pm
- po
- techlead
- uxui
- backend
- flutter
- security
- qa
- devops
- prcreator
- codereview

Examples:
- bash ./scripts/runmate-ops timeline 2
- bash ./scripts/runmate-ops run 2
- bash ./scripts/runmate-ops approve 2
- bash ./scripts/runmate-ops handoff 2
EOF
}

cmd_timeline() {
  local issue_number="${1:-}"
  if [[ -z "$issue_number" ]]; then
    echo "Usage: bash ./scripts/runmate-ops timeline <issue-number>" >&2
    exit 1
  fi

  local item_json
  item_json="$(issue_json "$issue_number")"
  if [[ "$item_json" == "null" || -z "$item_json" ]]; then
    echo "Issue not found in project." >&2
    exit 1
  fi

  ensure_issue_state "$issue_number" "$item_json"

  print_header
  echo "Timeline for #$issue_number $(jq -r '.title' <<<"$item_json")"
  echo

  jq -r --arg issue "$issue_number" '
    .issues[$issue] as $state
    | ($state.completed | length) as $idx
    | $state.flow
    | to_entries[]
    | if .key < $idx then
        "- [x] " + .value
      elif .key == $idx then
        "- [>] " + .value
      else
        "- [ ] " + .value
      end
    | sub("pm$"; "PM")
    | sub("po$"; "PO")
    | sub("techlead$"; "Tech Lead")
    | sub("uxui$"; "UX/UI")
    | sub("flutter$"; "Flutter Dev")
    | sub("backend$"; "Backend Dev")
    | sub("security$"; "Security")
    | sub("qa$"; "QA")
    | sub("devops$"; "DevOps")
    | sub("prcreator$"; "PR Creator")
    | sub("codereview$"; "Code Review")
  ' "$STATE_FILE"
}

cmd_agent() {
  local agent="${1:-}"
  local issue_number="${2:-}"

  if [[ -z "$agent" || -z "$issue_number" ]]; then
    echo "Usage: bash ./scripts/runmate-ops agent <agent> <issue-number>" >&2
    exit 1
  fi

  local agent_key file item_json current_key
  agent_key="$(normalize_agent_key "$agent")"
  file="$(agent_file "$agent_key")" || {
    echo "Unknown agent: $agent" >&2
    exit 1
  }

  item_json="$(issue_json "$issue_number")"
  if [[ "$item_json" == "null" || -z "$item_json" ]]; then
    echo "Issue not found in project." >&2
    exit 1
  fi

  ensure_issue_state "$issue_number" "$item_json"
  current_key="$(current_stage_key "$issue_number")"

  if [[ -n "$current_key" && "$agent_key" != "$current_key" ]]; then
    echo "Blocked: current allowed agent is $(agent_label "$current_key")." >&2
    echo "Use: bash ./scripts/runmate-ops timeline $issue_number" >&2
    exit 1
  fi

  local title area status sprint priority risk primary secondary url prompt
  title="$(jq -r '.title' <<<"$item_json")"
  area="$(jq -r '.area' <<<"$item_json")"
  status="$(jq -r '.status' <<<"$item_json")"
  sprint="$(jq -r '.sprint' <<<"$item_json")"
  priority="$(jq -r '.priority' <<<"$item_json")"
  risk="$(jq -r '.risk' <<<"$item_json")"
  primary="$(jq -r '."primary Agent"' <<<"$item_json")"
  secondary="$(jq -r '."secondary Agent"' <<<"$item_json")"
  url="$(jq -r '.content.url' <<<"$item_json")"
  prompt="$(extract_prompt_block "$file")"

  print_header
  cat <<EOF
Agent briefing

Agent: $(agent_label "$agent_key")
Issue: #$issue_number $title
Status: $status
Sprint: $sprint
Priority: $priority
Area: $area
Primary agent: $primary
Secondary agent: $secondary
Risk: $risk
URL: $url

Current process stage:
- $(agent_label "$agent_key")

Suggested handoff:
$(next_handoff_for_area "$area")

Prompt:

$prompt

Task context:

- Issue title: $title
- Area: $area
- Status: $status
- Sprint: $sprint
- Priority: $priority
- Risk: $risk
- Primary agent: $primary
- Secondary agent: $secondary

Use the GitHub issue body and acceptance criteria as the source of truth.
EOF
}

cmd_run() {
  local issue_number="${1:-}"
  if [[ -z "$issue_number" ]]; then
    echo "Usage: bash ./scripts/runmate-ops run <issue-number>" >&2
    exit 1
  fi

  local item_json current_key
  item_json="$(issue_json "$issue_number")"
  if [[ "$item_json" == "null" || -z "$item_json" ]]; then
    echo "Issue not found in project." >&2
    exit 1
  fi

  ensure_issue_state "$issue_number" "$item_json"
  current_key="$(current_stage_key "$issue_number")"

  if [[ -z "$current_key" ]]; then
    print_header
    echo "Task #$issue_number is already complete in the local process flow."
    exit 0
  fi

  cmd_agent "$current_key" "$issue_number"
}

cmd_approve() {
  local issue_number="${1:-}"
  local requested_agent="${2:-}"

  if [[ -z "$issue_number" ]]; then
    echo "Usage: bash ./scripts/runmate-ops approve <issue-number> [agent]" >&2
    exit 1
  fi

  local item_json current_key requested_key next_key
  item_json="$(issue_json "$issue_number")"
  if [[ "$item_json" == "null" || -z "$item_json" ]]; then
    echo "Issue not found in project." >&2
    exit 1
  fi

  ensure_issue_state "$issue_number" "$item_json"
  current_key="$(current_stage_key "$issue_number")"

  if [[ -z "$current_key" ]]; then
    print_header
    echo "Task #$issue_number is already complete."
    exit 0
  fi

  if [[ -n "$requested_agent" ]]; then
    requested_key="$(normalize_agent_key "$requested_agent")"
    if [[ "$requested_key" != "$current_key" ]]; then
      echo "Blocked: current allowed agent is $(agent_label "$current_key"), not $requested_agent." >&2
      exit 1
    fi
  fi

  approve_stage "$issue_number" "$current_key"
  next_key="$(next_stage_key "$issue_number")"

  print_header
  echo "Approved stage:"
  echo "- $(agent_label "$current_key")"
  echo
  if [[ -n "$next_key" ]]; then
    echo "Next unlocked stage:"
    echo "- $(agent_label "$next_key")"
    echo
    echo "Next command:"
    echo "- bash ./scripts/runmate-ops run $issue_number"
  else
    echo "Process complete for issue #$issue_number."
  fi
}

cmd_start() {
  local issue_number="${1:-}"
  if [[ -z "$issue_number" ]]; then
    echo "Usage: bash ./scripts/runmate-ops start <issue-number>" >&2
    exit 1
  fi

  local item_json current_key
  item_json="$(issue_json "$issue_number")"
  if [[ "$item_json" == "null" || -z "$item_json" ]]; then
    echo "Issue not found in project." >&2
    exit 1
  fi

  ensure_issue_state "$issue_number" "$item_json"
  current_key="$(current_stage_key "$issue_number")"

  print_header
  cat <<EOF
Start task

Issue:
- #$(jq -r '.content.number' <<<"$item_json") $(jq -r '.title' <<<"$item_json")

Execution lane:
- Area: $(jq -r '.area' <<<"$item_json")
- Current allowed agent: $(agent_label "$current_key")
- Process: $(next_handoff_for_area "$(jq -r '.area' <<<"$item_json")")

Suggested commands:
- bash ./scripts/runmate-ops timeline $issue_number
- bash ./scripts/runmate-ops run $issue_number
- bash ./scripts/runmate-ops approve $issue_number
EOF
}

cmd_handoff() {
  local issue_number="${1:-}"
  if [[ -z "$issue_number" ]]; then
    echo "Usage: bash ./scripts/runmate-ops handoff <issue-number>" >&2
    exit 1
  fi

  local item_json current_key next_key
  item_json="$(issue_json "$issue_number")"
  if [[ "$item_json" == "null" || -z "$item_json" ]]; then
    echo "Issue not found in project." >&2
    exit 1
  fi

  ensure_issue_state "$issue_number" "$item_json"
  current_key="$(current_stage_key "$issue_number")"
  next_key="$(next_stage_key "$issue_number")"

  print_header
  echo "Handoff plan"
  echo
  echo "Issue:"
  echo "- #$(jq -r '.content.number' <<<"$item_json") $(jq -r '.title' <<<"$item_json")"
  echo
  echo "Current stage:"
  echo "- $(agent_label "$current_key")"
  echo
  if [[ -n "$next_key" ]]; then
    echo "Next stage after approval:"
    echo "- $(agent_label "$next_key")"
  else
    echo "No further stages. Task flow is complete."
  fi
}

cmd_reset() {
  local issue_number="${1:-}"
  if [[ -z "$issue_number" ]]; then
    echo "Usage: bash ./scripts/runmate-ops reset <issue-number>" >&2
    exit 1
  fi

  ensure_state_file
  local tmp
  tmp="$(mktemp)"
  jq --arg issue "$issue_number" 'del(.issues[$issue])' "$STATE_FILE" >"$tmp"
  mv "$tmp" "$STATE_FILE"

  print_header
  echo "Reset local process state for issue #$issue_number."
}

usage() {
  cat <<'EOF'
Usage: bash ./scripts/runmate-ops <command>

Commands:
  summary           Show sprint and task summary
  ready             List tasks ready to be pulled
  next              Recommend the next task and required process
  team              Show the multi-agent operating model
  show <id>         Show details for an issue in the board
  agents            List available agents
  timeline <id>     Show the enforced process for an issue
  run <id>          Run the next allowed agent for an issue
  approve <id>      Approve the current stage and unlock the next one
  agent <name> <id> Run a specific agent only if that stage is unlocked
  start <id>        Show how to kick off an issue
  handoff <id>      Show the current and next handoff
  reset <id>        Reset local process state for an issue
EOF
}

main() {
  local cmd="${1:-summary}"
  shift || true

  case "$cmd" in
    summary) cmd_summary ;;
    ready) cmd_ready ;;
    next) cmd_next ;;
    team) cmd_team ;;
    show) cmd_show "$@" ;;
    agents) cmd_agents ;;
    timeline) cmd_timeline "$@" ;;
    run) cmd_run "$@" ;;
    approve) cmd_approve "$@" ;;
    agent) cmd_agent "$@" ;;
    start) cmd_start "$@" ;;
    handoff) cmd_handoff "$@" ;;
    reset) cmd_reset "$@" ;;
    *) usage; exit 1 ;;
  esac
}

main "$@"
